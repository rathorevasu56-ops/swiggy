# Copy this file to .env and fill in real values. Never commit .env itself.

# MongoDB connection string.
# Local MongoDB:   mongodb://127.0.0.1:27017/foodapp
# MongoDB Atlas:    mongodb+srv://<username>:<password>@<cluster-url>/foodapp?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/foodapp

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Port the API server listens on
PORT=5000
